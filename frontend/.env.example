# ── Modo protótipo (sem Firebase real) ──────────────────
# Defina como "true" para usar dados mockados e ignorar autenticação Firebase
VITE_MOCK_AUTH=true

# ── Firebase (necessário apenas quando VITE_MOCK_AUTH=false) ─
VITE_API_KEY=
VITE_AUTH_DOMAIN=
VITE_PROJECT_ID=
VITE_STORAGE_BUCKET=
VITE_MESSAGING_SENDER_ID=
VITE_APP_ID=
VITE_MEASUREMENT_ID=

# ── Backend ──────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
